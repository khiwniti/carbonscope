# Git
.git
.gitignore

# Node - exclude top-level node_modules but NOT those inside .next/standalone (needed for runtime)
node_modules
suna-init/node_modules
suna-init/apps/frontend/node_modules
suna-init/apps/mobile
**/.next/cache
**/.next/diagnostics
**/.turbo

# Python
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.venv
**/venv

# Logs
**/logs
*.log
npm-debug.log*

# Environment
.env.local
.env*.local

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Documentation
**/claudedocs
**/ROOT_CAUSE_*
README.md

# Tests
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts
**/tests
**/test
**/__tests__

# Mobile app (not needed for frontend build)
suna-init/apps/mobile/**

# Backend (not needed for frontend build)
suna-init/apps/backend/**
