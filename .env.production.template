# =============================================================================
# SUNA Production Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to create environment-specific configs:
#    - .env.production.frontend
#    - .env.production.backend
# 2. Fill in all values marked with YOUR_*
# 3. NEVER commit these files to git
# 4. Use Azure Key Vault for production secrets
# =============================================================================

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================

# Environment Mode
NEXT_PUBLIC_ENV_MODE=production

# Supabase Configuration (Frontend - Public Keys)
NEXT_PUBLIC_SUPABASE_URL=YOUR_PRODUCTION_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Backend API Configuration
NEXT_PUBLIC_BACKEND_URL=https://YOUR_DOMAIN/api/v1
NEXT_PUBLIC_URL=https://YOUR_DOMAIN

# Feature Flags
NEXT_PUBLIC_DISABLE_MOBILE_ADVERTISING=true
NEXT_PUBLIC_FORCE_LOCALHOST=false

# Analytics & Monitoring (Optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
NEXT_PUBLIC_POSTHOG_KEY=YOUR_POSTHOG_KEY
NEXT_PUBLIC_GTM_ID=YOUR_GTM_ID
NEXT_PUBLIC_GA_ID_1=YOUR_GA_ID_1
NEXT_PUBLIC_GA_ID_2=YOUR_GA_ID_2
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=YOUR_FACEBOOK_PIXEL_ID

# Vercel Edge Config (Optional)
EDGE_CONFIG=YOUR_EDGE_CONFIG_URL

# Admin API Key (Keep Secret!)
KORTIX_ADMIN_API_KEY=YOUR_ADMIN_API_KEY

# =============================================================================
# BACKEND ENVIRONMENT VARIABLES
# =============================================================================

# Python/Gunicorn Workers
WORKERS=4
TIMEOUT=75

# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SUPABASE_URL=YOUR_PRODUCTION_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_SSL=True

# Encryption Keys (GENERATE STRONG RANDOM VALUES!)
ENCRYPTION_KEY=YOUR_32_BYTE_BASE64_ENCRYPTION_KEY
MCP_CREDENTIAL_ENCRYPTION_KEY=YOUR_32_BYTE_BASE64_MCP_KEY

# External Services
DAYTONA_API_KEY=YOUR_DAYTONA_API_KEY

# Environment Mode
ENV_MODE=production

# =============================================================================
# SECURITY CHECKLIST
# =============================================================================
# [ ] All YOUR_* placeholders replaced with actual values
# [ ] Encryption keys generated with: openssl rand -base64 32
# [ ] Database uses SSL/TLS connection
# [ ] Redis password set and SSL enabled
# [ ] All secrets stored in Azure Key Vault
# [ ] Admin API key is strong (32+ characters)
# [ ] CORS properly configured in backend
# [ ] Rate limiting enabled
# [ ] Monitoring and alerting configured
# =============================================================================
