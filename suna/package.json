  "description": "BKS cBIM AI - Carbon Assessment Platform for Sustainable Construction",
  "keywords": ["bim", "carbon", "cbim", "sustainability", "EN15978", "lca", "green-building", "carbon-assessment"],
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter @bks/cbim-frontend dev",
